generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int         @id @default(autoincrement())
  nome       String      @db.VarChar(100)
  email      String      @unique @db.VarChar(150)
  senhaHash  String      @map("senha_hash") @db.VarChar(255)
  perfil     Perfil      @default(cliente)
  criadoEm   DateTime    @default(now()) @map("criado_em")
  avaliacoes Avaliacao[]
  avisos     Aviso[]
  carrinho   Carrinho?
  logs       LogAdmin[]
  pedidos    Pedido[]

  @@map("usuario")
}

model Colecao {
  id             Int       @id @default(autoincrement())
  nome           String    @db.VarChar(100)
  descricao      String?   @db.Text
  limiteProdutos Int       @map("limite_produtos")
  dataInicio     DateTime? @map("data_inicio")
  dataFim        DateTime? @map("data_fim")
  produtos       Produto[]

  @@map("colecao")
}

model Produto {
  id            Int            @id @default(autoincrement())
  idColecao     Int            @map("id_colecao")
  nome          String         @db.VarChar(150)
  descricao     String?        @db.Text
  preco         Decimal        @db.Decimal(10, 2)
  categoria     String         @db.VarChar(80)
  estilo        String?        @db.VarChar(80)
  avaliacoes    Avaliacao[]
  estoque       Estoque[]
  itensCarrinho ItemCarrinho[]
  itensPedido   ItemPedido[]
  colecao       Colecao        @relation(fields: [idColecao], references: [id])

  @@unique([nome, idColecao])
  @@index([idColecao], map: "produto_id_colecao_fkey")
  @@map("produto")
}

model Estoque {
  id         Int     @id @default(autoincrement())
  idProduto  Int     @map("id_produto")
  tamanho    String  @db.VarChar(10)
  cor        String  @db.VarChar(50)
  quantidade Int
  produto    Produto @relation(fields: [idProduto], references: [id])

  @@unique([idProduto, tamanho, cor])
  @@map("estoque")
}

model Carrinho {
  id        Int            @id @default(autoincrement())
  idUsuario Int            @unique @map("id_usuario")
  criadoEm  DateTime       @default(now()) @map("criado_em")
  usuario   Usuario        @relation(fields: [idUsuario], references: [id])
  itens     ItemCarrinho[]

  @@map("carrinho")
}

model ItemCarrinho {
  id         Int      @id @default(autoincrement())
  idCarrinho Int      @map("id_carrinho")
  idProduto  Int      @map("id_produto")
  quantidade Int
  tamanho    String   @db.VarChar(10)
  carrinho   Carrinho @relation(fields: [idCarrinho], references: [id])
  produto    Produto  @relation(fields: [idProduto], references: [id])

  @@index([idCarrinho], map: "item_carrinho_id_carrinho_fkey")
  @@index([idProduto], map: "item_carrinho_id_produto_fkey")
  @@map("item_carrinho")
}

model Pedido {
  id         Int          @id @default(autoincrement())
  idUsuario  Int          @map("id_usuario")
  valorTotal Decimal      @map("valor_total") @db.Decimal(10, 2)
  status     StatusPedido @default(pendente)
  criadoEm   DateTime     @default(now()) @map("criado_em")
  avaliacoes Avaliacao[]
  itens      ItemPedido[]
  usuario    Usuario      @relation(fields: [idUsuario], references: [id])

  @@index([idUsuario], map: "pedido_id_usuario_fkey")
  @@map("pedido")
}

model ItemPedido {
  id            Int     @id @default(autoincrement())
  idPedido      Int     @map("id_pedido")
  idProduto     Int     @map("id_produto")
  quantidade    Int
  precoUnitario Decimal @map("preco_unitario") @db.Decimal(10, 2)
  tamanho       String  @db.VarChar(10)
  pedido        Pedido  @relation(fields: [idPedido], references: [id])
  produto       Produto @relation(fields: [idProduto], references: [id])

  @@index([idPedido], map: "item_pedido_id_pedido_fkey")
  @@index([idProduto], map: "item_pedido_id_produto_fkey")
  @@map("item_pedido")
}

model Avaliacao {
  id         Int     @id @default(autoincrement())
  idUsuario  Int     @map("id_usuario")
  idProduto  Int     @map("id_produto")
  idPedido   Int     @map("id_pedido")
  nota       Int
  comentario String? @db.Text
  pedido     Pedido  @relation(fields: [idPedido], references: [id])
  produto    Produto @relation(fields: [idProduto], references: [id])
  usuario    Usuario @relation(fields: [idUsuario], references: [id])

  @@unique([idUsuario, idProduto, idPedido])
  @@index([idPedido], map: "avaliacao_id_pedido_fkey")
  @@index([idProduto], map: "avaliacao_id_produto_fkey")
  @@map("avaliacao")
}

model Aviso {
  id          Int      @id @default(autoincrement())
  idAdmin     Int      @map("id_admin")
  titulo      String   @db.VarChar(200)
  conteudo    String   @db.Text
  publicadoEm DateTime @default(now()) @map("publicado_em")
  admin       Usuario  @relation(fields: [idAdmin], references: [id])

  @@index([idAdmin], map: "aviso_id_admin_fkey")
  @@map("aviso")
}

model LogAdmin {
  id            Int      @id @default(autoincrement())
  idUsuario     Int      @map("id_usuario")
  acao          String   @db.VarChar(100)
  tabelaAfetada String   @map("tabela_afetada") @db.VarChar(80)
  executadoEm   DateTime @default(now()) @map("executado_em")
  usuario       Usuario  @relation(fields: [idUsuario], references: [id])

  @@index([idUsuario], map: "log_admin_id_usuario_fkey")
  @@map("log_admin")
}

enum Perfil {
  cliente
  administrador
}

enum StatusPedido {
  pendente
  confirmado
  enviado
  entregue
  cancelado
}
